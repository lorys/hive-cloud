{
  "name": "hive-cloud",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n build,server \"node build.mjs --watch\" \"node --watch --env-file-if-exists=.env.local dist/index.js\"",
    "build": "node --env-file-if-exists=.env.production build.mjs && cp src/website/index.html dist/index.html && cp -r assets/ dist/assets",
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "typecheck:server": "tsc -p tsconfig.json --noEmit",
    "typecheck:client": "tsc -p src/website/engine/tsconfig.json",
    "check": "npm run typecheck && npm run build",
    "start": "cd dist && node --env-file-if-exists=../.env.production index.js",
    "deploy": "npm run build && fly deploy",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
