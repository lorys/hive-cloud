{
  "name": "hive-cloud",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n server,client \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "node build.mjs --watch",
    "build:client": "node build.mjs",
    "typecheck:client": "tsc -p src/website/js/tsconfig.json",
    "build": "node build.mjs && tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
